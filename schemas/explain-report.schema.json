{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:ohrisk:schema:explain-report:3.2.0",
  "title": "Ohrisk explain report",
  "type": "object",
  "required": [
    "$schema",
    "schemaVersion",
    "status",
    "expression",
    "profile",
    "policyScope",
    "policy",
    "license",
    "finding"
  ],
  "properties": {
    "$schema": {
      "const": "urn:ohrisk:schema:explain-report:3.2.0"
    },
    "schemaVersion": {
      "const": "3.2.0"
    },
    "status": {
      "const": "license_explained"
    },
    "expression": {
      "type": "string",
      "minLength": 1
    },
    "profile": {
      "$ref": "urn:ohrisk:schema:common:3.2.0#/$defs/usageProfile"
    },
    "policyScope": {
      "const": "license-only"
    },
    "policy": {
      "$ref": "urn:ohrisk:schema:common:3.2.0#/$defs/policySummary"
    },
    "license": {
      "$ref": "urn:ohrisk:schema:common:3.2.0#/$defs/normalizedLicense"
    },
    "finding": {
      "$ref": "urn:ohrisk:schema:common:3.2.0#/$defs/riskFinding"
    }
  },
  "additionalProperties": false
}
