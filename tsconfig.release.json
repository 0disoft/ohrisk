{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
    "types": [
      "bun",
      "node"
    ],
    "skipLibCheck": true,
    "allowImportingTsExtensions": true,
    "noEmit": true
  },
  "files": [
    "scripts/build.ts",
    "scripts/package-smoke.ts",
    "src/cli/version.ts",
    "src/report/write-output.ts"
  ]
}
