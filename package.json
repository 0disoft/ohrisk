{
  "name": "ohrisk",
  "version": "0.68.0",
  "description": "Catch open-source license risk before your PR ships.",
  "license": "MIT",
  "type": "module",
  "packageManager": "bun@1.3.14",
  "engines": {
    "bun": ">=1.3.0"
  },
  "bin": {
    "ohrisk": "./src/cli/main.ts"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/0disoft/ohrisk.git"
  },
  "bugs": {
    "url": "https://github.com/0disoft/ohrisk/issues"
  },
  "homepage": "https://github.com/0disoft/ohrisk#readme",
  "keywords": [
    "bun",
    "cli",
    "compliance",
    "license",
    "open-source",
    "risk",
    "supply-chain"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "scan": "bun run src/cli/main.ts scan",
    "test": "bun test",
    "verify:release": "bun test && npm pack --dry-run --json && bun run scripts/package-smoke.ts"
  },
  "files": [
    "CHANGELOG.md",
    "src"
  ],
  "dependencies": {
    "@yarnpkg/lockfile": "1.1.0",
    "yaml": "2.9.0"
  }
}
